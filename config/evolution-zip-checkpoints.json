{
  "program": "Atlas V3 Evolution 1000",
  "interval": 50,
  "firstCheckpoint": 50,
  "lastCheckpoint": 1000,
  "nextCheckpoint": 50,
  "latestClosedCheckpoint": 0,
  "artifactPattern": "atlas-v3-phase-{phase}-hostinger.zip",
  "target": "Hostinger Node.js 20.9+",
  "preservePreviousArtifacts": true,
  "requiredValidation": [
    "phase check",
    "evolution-1000 check",
    "typecheck",
    "lint",
    "build",
    "package integrity"
  ],
  "privateDataPolicy": {
    "envLocalIncluded": false,
    "secretsIncluded": false,
    "spreadsheetsIncluded": false,
    "pdfsIncluded": false,
    "customerDataIncluded": false,
    "envExampleIncluded": true
  },
  "checkpoints": [
    50,
    100,
    150,
    200,
    250,
    300,
    350,
    400,
    450,
    500,
    550,
    600,
    650,
    700,
    750,
    800,
    850,
    900,
    950,
    1000
  ]
}
