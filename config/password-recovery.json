{
  "version": 1,
  "requestPath": "/forgot-password",
  "callbackPath": "/auth/callback",
  "resetPath": "/reset-password",
  "serverResetApi": "/api/auth/password-reset",
  "intentCookie": {
    "name": "atlas-recovery-intent",
    "httpOnly": true,
    "sameSite": "strict",
    "maxAgeSeconds": 900,
    "secureInProduction": true
  },
  "passwordPolicy": {
    "minimumLength": 12,
    "maximumLength": 128,
    "minimumCharacterCategories": 3
  },
  "requestRateLimit": { "attempts": 5, "windowMinutes": 15 },
  "resetRateLimit": { "attempts": 5, "windowMinutes": 15 },
  "invalidateSessionsAfterReset": "global",
  "enumerationSafe": true,
  "externalHomologation": ["delivery", "latest-link", "expired-link", "used-link", "wrong-domain", "global-session-revocation"]
}
