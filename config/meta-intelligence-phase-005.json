{
  "program": "Atlas Meta Signal Intelligence",
  "phase": 5,
  "title": "Especificacao do bridge de compatibilidade e matriz RLS/grants",
  "mode": "specification_only",
  "status": "blocked",
  "safeToApply": false,
  "canonicalSources": {
    "tenantContext": "private.current_organization_id()",
    "projects": "public.crm_projects",
    "campaigns": "public.marketing_campaigns",
    "leads": "public.leads",
    "profiles": "public.profiles"
  },
  "bridgeContracts": [
    {
      "name": "tenant_context_policy_contract",
      "kind": "direct_private_helper",
      "source": "private.current_organization_id()",
      "target": "RLS policies",
      "publicAliasAllowed": false,
      "securityInvoker": true,
      "readOnly": true,
      "applyNow": false,
      "invariants": [
        "authenticated_session_required",
        "organization_id_never_accepted_from_client",
        "tenant_predicate_present_on_every_exposed_ledger"
      ]
    },
    {
      "name": "lead_visibility_policy_contract",
      "kind": "private_security_definer_helper",
      "source": "public.leads",
      "target": "private.can_view_lead(uuid)",
      "publicAliasAllowed": false,
      "securityDefiner": true,
      "emptySearchPathRequired": true,
      "publicExecuteRevoked": true,
      "authenticatedExecuteExplicit": true,
      "readOnly": true,
      "applyNow": false,
      "invariants": [
        "auth_uid_required",
        "same_organization_required",
        "commercial_hierarchy_enforced",
        "lead_id_parameter_only"
      ]
    },
    {
      "name": "projects_compatibility_adapter",
      "kind": "security_invoker_view",
      "source": "public.crm_projects",
      "target": "public.developments_compat",
      "securityInvoker": true,
      "sourceRlsRequired": true,
      "readOnly": true,
      "foreignKeyTargetAllowed": false,
      "canonicalWriteTarget": "public.crm_projects",
      "applyNow": false,
      "invariants": [
        "no_duplicate_developments_table",
        "no_write_through_view",
        "source_ids_preserved"
      ]
    },
    {
      "name": "campaigns_compatibility_adapter",
      "kind": "security_invoker_view",
      "source": "public.marketing_campaigns",
      "target": "public.campaigns_compat",
      "securityInvoker": true,
      "sourceRlsRequired": true,
      "readOnly": true,
      "foreignKeyTargetAllowed": false,
      "canonicalWriteTarget": "public.marketing_campaigns",
      "applyNow": false,
      "invariants": [
        "no_duplicate_campaigns_table",
        "no_write_through_view",
        "source_ids_preserved"
      ]
    },
    {
      "name": "commercial_hierarchy_additive_contract",
      "kind": "additive_columns",
      "source": "public.profiles",
      "target": "public.profiles",
      "columns": ["commercial_role", "reports_to"],
      "destructiveRewriteAllowed": false,
      "backfillIncluded": false,
      "applyNow": false,
      "invariants": [
        "existing_role_preserved",
        "existing_profiles_preserved",
        "hierarchy_activation_requires_separate_reviewed_backfill"
      ]
    },
    {
      "name": "lead_reference_contract",
      "kind": "existing_identity_reference",
      "source": "public.leads.id",
      "target": "Meta event ledgers",
      "massLeadRewriteAllowed": false,
      "leadBackfillIncluded": false,
      "applyNow": false,
      "invariants": [
        "existing_lead_id_preserved",
        "project_context_stored_without_rewriting_live_lead",
        "campaign_context_stored_without_rewriting_live_lead"
      ]
    }
  ],
