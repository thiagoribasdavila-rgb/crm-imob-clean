    { "name": "NEXT_PUBLIC_SUPABASE_ANON_KEY", "scope": "public", "requirement": "alternative", "group": "supabaseBrowserKey", "secret": false, "purpose": "Chave anon legada do Supabase para o navegador." },
    { "name": "NEXT_PUBLIC_APP_URL", "scope": "public", "requirement": "optional", "secret": false, "purpose": "URL pública canônica da interface." },

    { "name": "SUPABASE_SERVICE_ROLE_KEY", "scope": "server", "requirement": "required", "secret": true, "purpose": "Acesso administrativo do servidor ao Supabase." },
