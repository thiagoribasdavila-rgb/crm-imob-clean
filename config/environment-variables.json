{
  "version": 1,
  "alternativeGroups": {
    "supabaseBrowserKey": {
      "minimumConfigured": 1,
      "members": ["NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY", "NEXT_PUBLIC_SUPABASE_ANON_KEY"],
      "purpose": "Chave pública do cliente Supabase; prefira publishable em instalações novas."
    }
  },
