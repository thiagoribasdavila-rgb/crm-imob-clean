# Atlas AI — ambiente local e homologação
# Copie para .env.local e preencha somente os valores.
# Nunca envie .env.local ao GitHub ou ao chat.

# Supabase — obrigatórias
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Segurança operacional — obrigatória para workers/cron
ATLAS_CRON_SECRET=

# Bootstrap — temporária; remova após criar o primeiro administrador
ATLAS_BOOTSTRAP_SECRET=

# Teste autenticado — use uma conta exclusiva de homologação
ATLAS_TEST_EMAIL=
ATLAS_TEST_PASSWORD=

# Reset oficial de acessos — temporárias; remova depois da homologação.
ATLAS_AUTH_ORGANIZATION_ID=
ATLAS_RECOVERY_INBOX=
ATLAS_INITIAL_ADMIN_EMAIL=
ATLAS_INITIAL_THIAGO_EMAIL=
ATLAS_INITIAL_SENNA_EMAIL=
ATLAS_INITIAL_DIEGO_EMAIL=
ATLAS_INITIAL_LUCIANO_EMAIL=
ATLAS_INITIAL_ADOLFO_EMAIL=

# Identidade do ambiente local. Na Hostinger, use homologation ou production com domínio HTTPS.
ATLAS_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
ATLAS_ENV=development
ATLAS_DEFAULT_ORGANIZATION_ID=
ATLAS_ENVIRONMENT_ID=atlas-v3-local
ATLAS_DATABASE_ENVIRONMENT=development
ATLAS_HOSTING_PROVIDER=local

# Materiais dos incorporadores — opcional, privado e compatível com S3/R2
# Mantenha "supabase" durante a migração; troque para "s3" após o ensaio validado.
ATLAS_MATERIAL_STORAGE_PROVIDER=supabase
ATLAS_OBJECT_STORAGE_ENDPOINT=
ATLAS_OBJECT_STORAGE_REGION=auto
ATLAS_OBJECT_STORAGE_BUCKET=
ATLAS_OBJECT_STORAGE_ACCESS_KEY_ID=
ATLAS_OBJECT_STORAGE_SECRET_ACCESS_KEY=
ATLAS_OBJECT_STORAGE_FORCE_PATH_STYLE=false


# Provedores de IA diretos — executados no servidor Hostinger
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
DEEPSEEK_API_KEY=
ATLAS_DEEPSEEK_MODEL=deepseek-v4-flash
QWEN_API_KEY=
ATLAS_QWEN_MODEL=
KIMI_API_KEY=
ATLAS_KIMI_MODEL=
GLM_API_KEY=
ATLAS_GLM_MODEL=
# Ordem econômica; contextos com dados pessoais usam somente OpenAI.
ATLAS_AI_FAST_PROVIDER_ORDER=qwen,deepseek,openai
ATLAS_AI_COMMERCIAL_PROVIDER_ORDER=openai,qwen,kimi
ATLAS_AI_REASONING_PROVIDER_ORDER=openai,deepseek,glm,kimi
ATLAS_AI_MODEL=gpt-5.2
ATLAS_AI_FAST_MODEL=gpt-5-mini
ATLAS_AI_COMMERCIAL_MODEL=gpt-5.2
ATLAS_AI_REASONING_MODEL=gpt-5.2
ATLAS_RESEARCH_MODEL=sonar
# Preencha com os preços vigentes dos modelos escolhidos; nunca estime silenciosamente.
ATLAS_AI_FAST_INPUT_USD_PER_MILLION=
ATLAS_AI_FAST_OUTPUT_USD_PER_MILLION=
ATLAS_AI_COMMERCIAL_INPUT_USD_PER_MILLION=
ATLAS_AI_COMMERCIAL_OUTPUT_USD_PER_MILLION=
ATLAS_AI_REASONING_INPUT_USD_PER_MILLION=
ATLAS_AI_REASONING_OUTPUT_USD_PER_MILLION=
ATLAS_AI_RESEARCH_INPUT_USD_PER_MILLION=
ATLAS_AI_RESEARCH_OUTPUT_USD_PER_MILLION=

# Integrações externas — opcionais no primeiro teste
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_LEAD_ACCESS_TOKEN=
META_CONVERSIONS_ACCESS_TOKEN=
META_ADS_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_GRAPH_API_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_NIGHTLY_APPROACH_TEMPLATE=
WHATSAPP_TEST_RECIPIENT=
# WhatsApp Intelligence (entrada por LLM) — desligado por padrão. Ligar apenas
# após aplicar a migration whatsapp_message_insights. Cada resposta de cliente
# passa a gerar análise por IA (custo de LLM). Dados pessoais → rota OpenAI-only.
ATLAS_WHATSAPP_NLU_ENABLED=false
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
MICROSOFT_CALENDAR_CLIENT_ID=
MICROSOFT_CALENDAR_CLIENT_SECRET=
MICROSOFT_CALENDAR_REDIRECT_URI=
TIKTOK_ADS_ACCESS_TOKEN=

# Importações supervisionadas — temporárias; limpe ao concluir cada carga
ATLAS_IMPORT_ORGANIZATION_ID=
ATLAS_IMPORT_OWNER_ID=
ATLAS_IMPORT_ACTOR_ID=
