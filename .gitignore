# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist/
/outputs/
/tmp/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/logs/*.log
/.atlas-route-quarantine-*
/.atlas-route-quarantine.lock

# env files (can opt-in for committing if needed)
.env*
hostinger.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma
.env.local

# backups locais de env (nunca versionar)
_env_bak_to_delete/
*.bak
*.env.bak

# cache local do Supabase CLI (specific da máquina, nunca versionar)
supabase/.temp/

# output solto de `supabase migration list` (relatório pontual, não é fonte)
migration-status.txt
migrations.json
