{
  "name": "atlas-ai-real-estate-os",
  "version": "3.0.0-rc.2",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "enterprise:check": "node scripts/enterprise-check.mjs",
    "security:secrets": "node scripts/scan-secrets.mjs",
    "inventory:v3": "node scripts/inventory-v3.mjs",
    "architecture:canonical": "node scripts/check-canonical-entities.mjs",
    "contracts:data": "node scripts/check-data-contracts.mjs",
    "architecture:modules": "node scripts/check-module-boundaries.mjs",
    "environments:check": "node scripts/check-environments.mjs",
    "environment:variables": "node scripts/check-environment-variables.mjs",
    "security:governance": "node scripts/check-secret-governance.mjs",
    "observability:check": "node scripts/check-observability.mjs",
    "ai:calibration": "node scripts/test-real-estate-ai.mjs",
    "validate": "npm run security:secrets && npm run security:governance && npm run observability:check && npm run inventory:v3 && npm run architecture:canonical && npm run contracts:data && npm run architecture:modules && npm run environments:check && npm run environment:variables && npm run enterprise:check && npm run ai:calibration && npm run typecheck && npm run lint && npm run build",
    "release:check": "npm run validate",
    "v1-v2:check": "npm run release:check",
    "v3:check": "npm run release:check",
    "smoke:v1-v2": "node scripts/smoke-v1-v2.mjs",
    "smoke:v3": "node scripts/smoke-v3.mjs",
    "smoke:all": "npm run smoke:v1-v2 && npm run smoke:v3",
    "prepare:test": "node scripts/prepare-real-test.mjs",
    "routes:real": "node --env-file=.env.local scripts/test-real-routes.mjs",
    "preflight:production": "node scripts/preflight-production.mjs",
    "package:hostinger": "node scripts/package-hostinger.mjs",
    "worker:run": "node scripts/run-workers.mjs",
    "reports:meta-daily": "node scripts/run-daily-meta-report.mjs",
    "test:real": "npm run release:check && npm run smoke:all && npm run routes:real && npm run preflight:production",
    "prisma:generate": "prisma generate",
    "doctor": "node scripts/doctor.mjs",
    "bootstrap:admin": "node --env-file=.env.local scripts/bootstrap-admin.mjs",
    "bootstrap:diagnose": "node --env-file=.env.local scripts/diagnose-bootstrap.mjs",
    "project:import:in-perdizes": "node --env-file=.env.local scripts/import-in-perdizes.mjs",
    "leads:import:memory": "node --env-file=.env.local scripts/import-prepared-lead-memory.mjs",
    "setup:atlas": "npm ci && npm run prisma:generate && npm run doctor && npm run release:check"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1089.0",
    "@aws-sdk/s3-request-presigner": "3.1089.0",
    "@prisma/client": "^7.8.0",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "ai": "^7.0.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "radix-ui": "^1.6.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": "24.x"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.19"
  }
}
